<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Panel administrador de Orígenes Colombia" />
  <title>Administrador | Orígenes Colombia</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <link href="../CSS/base.css" rel="stylesheet" />
  <link href="../CSS/navbar.css" rel="stylesheet" />
  <link href="../CSS/carrito.css" rel="stylesheet" />

<link href="../CSS/header.css" rel="stylesheet"/>
<link href="../CSS/footer.css" rel="stylesheet"/>
<link href="../CSS/admin.css" rel="stylesheet"/>
<link href="../CSS/carrito-global.css" rel="stylesheet"/>
<link href="../CSS/estilo-final.css" rel="stylesheet"/>
</head>

<body id="top">
  <nav class="navbar navbar-expand-lg custom-navbar fixed-top" id="inicio">
    <div class="container nav-wrapper">
      <a class="navbar-brand" href="../index.html">
        <img alt="Orígenes Colombia" class="logo-navbar" src="../IMG/logo-origenes-oscuro.svg" />
      </a>

      <button aria-controls="navbarMain" aria-expanded="false" aria-label="Abrir menú" class="navbar-toggler" data-bs-target="#navbarMain" data-bs-toggle="collapse" type="button">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-between" id="navbarMain">
        <ul class="navbar-nav mx-auto nav-center">
          <li class="nav-item"><a class="nav-link" href="../index.html">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="./catalogo.html">Catálogo</a></li>
          <li class="nav-item"><a class="nav-link" href="./contactenos.html">Contacto</a></li>
          <li class="nav-item"><a class="nav-link" href="./sobreorigenes.html">Sobre Orígenes</a></li>
          <li class="nav-item"><a class="nav-link active-link" href="./admin.html">Administrador</a></li>
        </ul>

        <div class="icons">
          <a id="loginLink" class="nav-session-link" href="./login.html">Iniciar Sesión</a>
          <span id="userGreeting" class="nav-user-greeting" hidden>
            Hola, <span id="userGreetingName"></span>
          </span>
          <button id="logoutBtn" class="nav-logout-btn" type="button" hidden>Cerrar Sesión</button>

          <a aria-label="Perfil" id="profileLink" href="./registro.html">
            <img alt="Usuario" class="nav-icon" src="../IMG/icon-usuario.svg" />
          </a>
          <button aria-label="Carrito" class="cart-icon-btn" id="cartBtn" type="button">
            <img alt="Carrito" class="nav-icon" src="../IMG/icon-bolsa.svg" />
            <span class="cart-badge" id="cartCount">0</span>
          </button>
        </div>
      </div>
    </div>
  </nav>


  <main>
    <section class="admin-hero">
      <div class="admin-hero-overlay">
        <div class="container text-center hero-content">
          <h1 class="admin-hero-title">Panel Administrador</h1>
          <p class="admin-hero-text">Gestiona productos del catálogo de forma rápida, clara y organizada.</p>
        </div>
      </div>
    </section>

    <section class="admin-section">
      <div class="container">
        <div class="text-center intro-block">
          <h2 class="section-title">Gestión de productos</h2>
          <p class="admin-intro">Desde este panel puedes registrar nuevos productos con su nombre, descripción, precio, categoría, stock e imagen.</p>
        </div>

        <div class="admin-layout">
          <div class="admin-form-card">
            <div class="admin-card-header">
              <span class="mini-label">Nuevo producto</span>
              <h3 class="admin-card-title">Crear producto</h3>
              <p class="admin-card-description">Completa la información del producto para agregarlo al catálogo.</p>
            </div>

            <div class="admin-form-body">
              <form id="productForm">
                <input id="productId" type="hidden" />

                <div class="mb-3">
                  <label class="form-label" for="name">Nombre del producto</label>
                  <input class="form-control" id="name" placeholder="Ej: Café Premium de Nariño" required type="text" />
                </div>

                <div class="mb-3">
                  <label class="form-label" for="description">Descripción</label>
                  <textarea class="form-control" id="description" placeholder="Describe el producto" required rows="4"></textarea>
                </div>

                <div class="row g-3 mb-3">
                  <div class="col-md-6">
                    <label class="form-label" for="price">Precio</label>
                    <input class="form-control" id="price" min="1" placeholder="Ej: 45000" required step="1" type="number" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label" for="stock">Cantidad disponible</label>
                    <input class="form-control" id="stock" min="0" placeholder="Ej: 12" required step="1" type="number" />
                  </div>
                </div>

                <div class="mb-3">
                  <label class="form-label" for="category">Categoría</label>
                  <select class="form-select" id="category" required>
                    <option value="">Selecciona una categoría</option>
                    <option value="Café">Café</option>
                    <option value="Artesanías">Artesanías</option>
                    <option value="Moda">Moda</option>
                    <option value="Decoración">Decoración</option>
                    <option value="Alimentos">Alimentos</option>
                  </select>
                </div>

                <div class="mb-4">
                  <label class="form-label" for="image">URL o ruta de la imagen</label>
                  <input class="form-control" id="image" placeholder="Ej: ../IMG/producto.jpg" required type="text" />
                </div>

                <div class="admin-actions admin-actions-gap">
                  <button class="btn btn-admin" id="submitBtn" type="submit">Guardar producto</button>
                  <button class="btn btn-admin-outline" id="cancelEditBtn" type="button">Cancelar edición</button>
                </div>
              </form>
            </div>
          </div>

          <div class="admin-products-card">
            <div class="admin-card-header">
              <span class="mini-label">Catálogo actual</span>
              <h3 class="admin-card-title">Lista de productos</h3>
              <p class="admin-card-description">Aquí verás los productos agregados en tiempo real.</p>
            </div>
            <div class="admin-products-body">
              <div class="row g-4 justify-content-center" id="productList"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>


  <aside class="cart-drawer" id="cartDrawer">
    <div class="cart-header">
      <h3>Tu carrito</h3>
      <button class="cart-close-btn" id="closeCart" type="button">×</button>
    </div>
    <div class="cart-items" id="cartItems"></div>
    <div class="cart-footer">
      <p class="cart-total">Total: <span id="total">$0</span></p>
      <div class="cart-footer-actions">
        <button class="btn-cart-secondary" id="clearCartBtn" type="button">Vaciar</button>
        <button class="btn-cart-primary" id="buyBtn" type="button">Comprar</button>
      </div>
    </div>
  </aside>

  <div class="cart-overlay" id="cartOverlay"></div>

  <footer class="site-footer">
    <div class="container">
      <div class="row footer-content">
        <div class="col-md-4">
          <h6 class="footer-title">Contacto</h6>
          <ul class="footer-list">
            <li>Calle Ficticia #123, Cali, Colombia</li>
            <li>Lunes a Viernes 8:00 AM - 6:00 PM</li>
            <li>contactoorigenescolombia@gmail.com</li>
            <li>+57 312 3456 7890</li>
          </ul>
          <div class="icons">
            <a aria-label="Facebook" href="#"><img alt="Facebook" src="../IMG/icon-facebook.svg" /></a>
            <a aria-label="Instagram" href="#"><img alt="Instagram" src="../IMG/icon-instagram.svg" /></a>
            <a aria-label="YouTube" href="#"><img alt="YouTube" src="../IMG/icon-youtube.svg" /></a>
            <a aria-label="X" href="#"><img alt="X" src="../IMG/icon-x.svg" /></a>
            <a aria-label="WhatsApp" href="#"><img alt="WhatsApp" src="../IMG/icon-whatsapp.svg" /></a>
          </div>
        </div>

        <div class="col-md-4">
