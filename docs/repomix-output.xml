<file path="CSS/about.css">
/* Sobre Orígenes */
.about-hero {
  height: 470px;
  background-image:
    linear-gradient(rgba(0, 0, 0, 0.34), rgba(0, 0, 0, 0.34)),
    url("../IMG/hero-artesanal-colombia.jpg");
  background-position: center center;
  background-size: cover;
  background-repeat: no-repeat;
  display: flex;
  align-items: center;
}

.about-hero-overlay {
  width: 100%;
}

.about-hero-title {
  color: var(--textoblanco);
  font-size: clamp(2.8rem, 5vw, 4.9rem);
  font-weight: 700;
  margin-bottom: 14px;
}

.about-hero-text {
  color: var(--textoblanco);
  font-size: 1.2rem;
  margin: 0;
}

.about-section {
  padding: 30px 0 60px;
}

.intro-block {
  max-width: 950px;
  margin: 0 auto 20px;
}

.section-title {
  color: var(--navbackground);
  font-size: clamp(2.4rem, 3vw, 3.1rem);
  font-weight: 700;
  margin-bottom: 8px;
}

.about-intro,
.team-subtitle {
  max-width: 980px;
  margin: 0 auto;
  font-size: 1.02rem;
  line-height: 1.45;
  color: var(--colortextos);
}

.about-cards {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 26px;
  margin-top: 26px;
  margin-bottom: 26px;
}

.about-box {
  background: #ffffff;
  border: 1px solid var(--bordercolor);
  border-radius: 22px;
  padding: 26px 24px 24px;
  box-shadow: var(--shadowsoft);
}

.about-box-header {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
}

.about-icon {
  width: 74px;
  min-width: 74px;
  height: 74px;
  border-radius: 50%;
  background: var(--navbackground);
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-icon i {
  color: var(--textoblanco);
  font-size: 2rem;
}

.about-box-title {
  margin: 0;
  color: var(--navbackground);
  font-size: 2rem;
  font-weight: 700;
}

.about-box-text {
  margin: 0;
  font-size: 1rem;
  line-height: 1.6;
  color: var(--colortextos);
}

.values-list {
  margin: 0;
  padding-left: 24px;
  font-size: 1rem;
  line-height: 1.6;
}

.values-list li + li {
  margin-top: 8px;
}

.team-heading {
  margin-top: 8px;
  margin-bottom: 18px;
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(170px, 1fr));
  gap: 14px;
  align-items: stretch;
}

.team-card {
  background: #ffffff;
  border: 1px solid var(--bordercolor);
  border-radius: 18px;
  overflow: hidden;
  box-shadow: var(--shadowsoft);
  display: flex;
  flex-direction: column;
}

.img1 {
  height: 78px;
  overflow: hidden;
}

.img1 img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.img2 {
  display: flex;
  justify-content: center;
  margin-top: -32px;
  margin-bottom: 6px;
}

.img2 img {
  width: 96px;
  height: 96px;
  border-radius: 50%;
  object-fit: cover;
  border: 4px solid #ffffff;
  background: #ffffff;
}

.team-card-body {
  padding: 10px 12px 16px;
  text-align: center;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.card-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #202020;
  margin-bottom: 6px;
}

.card-role {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--navbackground);
  margin-bottom: 8px;
}

.card-text {
  font-size: 0.82rem;
  line-height: 1.35;
  margin-bottom: 10px;
  color: var(--colortextos);
  min-height: 58px;
}

.social {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 14px;
  margin-top: auto;
}

.social a {
  color: var(--navbackground);
  font-size: 1.7rem;
  transition: color 0.3s ease, transform 0.3s ease;
}

.social a:hover {
  color: var(--colorhover);
  transform: translateY(-2px);
}

@media (max-width: 1199px) {
  .about-cards {
    grid-template-columns: 1fr;
  }

  .team-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 767px) {
  .about-hero {
    height: 300px;
  }

  .about-hero-title {
    font-size: 2.2rem;
  }

  .about-hero-text {
    font-size: 1rem;
    padding: 0 10px;
  }

  .section-title {
    font-size: 2rem;
  }

  .team-grid {
    grid-template-columns: 1fr;
  }

  .about-box-header {
    flex-direction: column;
    text-align: center;
  }
}
