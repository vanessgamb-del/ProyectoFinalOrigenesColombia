<file path="CSS/contactenos.css">
/* Contacto */
.contact-hero {
  height: 390px;
  background-image:
    linear-gradient(rgba(0, 0, 0, 0.34), rgba(0, 0, 0, 0.34)),
    url("../IMG/contacto-artesanal-opcion-2.png");
  background-position: center center;
  background-size: cover;
  background-repeat: no-repeat;
  display: flex;
  align-items: center;
}

.contact-hero-overlay {
  width: 100%;
}

.hero-content {
  padding-top: 24px;
}

.contact-hero-title {
  color: var(--textoblanco);
  font-size: clamp(2.6rem, 5vw, 4.6rem);
  font-weight: 700;
  margin-bottom: 14px;
}

.contact-hero-text {
  color: var(--textoblanco);
  font-size: 1.1rem;
  margin: 0;
}

.contact-section {
  padding: 38px 0 60px;
}

.contact-intro {
  max-width: 820px;
  margin: 0 auto;
  font-size: 1rem;
  line-height: 1.55;
  color: var(--colortextos);
}

.contact-layout {
  display: grid;
  grid-template-columns: 1fr 1.08fr;
  gap: 28px;
  align-items: stretch;
}

.contact-info-card,
.contact-form-card {
  background: var(--cardbg);
  border: 1px solid var(--bordercolor);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: var(--shadowsoft);
}

.contact-image-wrapper {
  position: relative;
  height: 300px;
  overflow: hidden;
}

.contact-side-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.contact-image-badge {
  position: absolute;
  left: 24px;
  bottom: 24px;
  padding: 14px 26px;
  border-radius: 999px;
  background: var(--gradientbadge);
  color: #FFFFFF;
  font-size: 1rem;
  font-weight: 800;
  letter-spacing: 0.3px;
  box-shadow:
    0 10px 24px rgba(0, 0, 0, 0.28),
    inset 0 1px 1px rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.contact-info-content {
  padding: 24px;
}

.contact-info-content h3,
.form-title {
  background: var(--gradientdark);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-size: 1.9rem;
  font-weight: 800;
  margin-bottom: 12px;
}

.contact-info-content p {
  font-size: 0.97rem;
  line-height: 1.65;
  margin-bottom: 18px;
}

.contact-info-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 0.96rem;
  line-height: 1.5;
}

.contact-form {
  padding: 28px 28px 24px;
}

.mini-label {
  display: inline-block;
  background: var(--gradientbadge);
  color: #FFFFFF;
  border-radius: 999px;
  padding: 7px 14px;
  font-size: 0.8rem;
  font-weight: 800;
  margin-bottom: 12px;
}

.form-description {
  margin-bottom: 24px;
  font-size: 0.96rem;
  line-height: 1.6;
  color: var(--colortextos);
}

.form-label {
  font-weight: 600;
  color: var(--colortextos);
  margin-bottom: 8px;
}

.contact-form .form-control,
.contact-form .form-select {
  border: 1px solid #D9D2C7;
  border-radius: 14px;
  background-color: #FFFFFF;
  min-height: 52px;
  padding: 12px 14px;
  box-shadow: none;
  color: var(--colortextos);
}

.contact-form .form-control:focus,
.contact-form .form-select:focus {
  border-color: #6B5B4D;
  box-shadow: 0 0 0 0.16rem rgba(107, 91, 77, 0.18);
}

textarea.form-control {
  min-height: 130px;
  resize: vertical;
}

.text-danger {
  display: block;
  margin-top: 6px;
  font-size: 0.84rem;
}

.contact-actions {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
  margin-top: 8px;
}

.submit-btn {
  background-color: #FFFFFF;
  color: var(--navbackground);
  border: none;
  border-radius: 999px;
  padding: 14px 32px;
  min-width: 200px;
  font-weight: 800;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.10);
  transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}

.submit-btn:hover {
  background-color: var(--navbackground);
  color: #FFFFFF;
  transform: translateY(-2px);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.16);
}

.success-box {
  margin: 20px 24px 24px;
  border-radius: 14px;
  border: none;
  box-shadow: var(--shadowsoft);
}

@media (max-width: 1199px) {
  .contact-layout {
    grid-template-columns: 1fr;
  }

  .contact-image-wrapper {
    height: 340px;
  }
}

@media (max-width: 767px) {
  .contact-hero {
    height: 270px;
  }

  .contact-hero-title {
    font-size: 2.2rem;
  }

  .contact-hero-text {
    font-size: 1rem;
    padding: 0 10px;
  }

  .contact-form,
  .contact-info-content {
    padding: 22px 18px 20px;
  }

  .contact-actions {
    flex-direction: column;
    align-items: stretch;
  }

  .submit-btn {
    width: 100%;
  }

  .contact-image-badge {
    left: 12px;
    right: 12px;
    justify-content: center;
    text-align: center;
  }
}
</file>

