<file path="JS/navbar.js">
document.addEventListener("DOMContentLoaded", () => {
  const loginLink = document.getElementById("loginLink");
  const greeting = document.getElementById("userGreeting");
  const greetingName = document.getElementById("userGreetingName");
  const logoutBtn = document.getElementById("logoutBtn");

  // Si la página no expone los placeholders del navbar dinámico,
  // salimos en silencio en vez de lanzar errores.
  if (!loginLink || !greeting || !greetingName || !logoutBtn) {
    return;
  }

  function pintarEstadoSesion() {
    const usuario = getUsuarioActivo();

    if (usuario && usuario.nombre) {
      greetingName.textContent = capitalizarNombre(usuario.nombre);
      loginLink.hidden = true;
      greeting.hidden = false;
      logoutBtn.hidden = false;
    } else {
      loginLink.hidden = false;
      greeting.hidden = true;
      logoutBtn.hidden = true;
    }
  }

  logoutBtn.addEventListener("click", () => {
    cerrarSesion();
    // Recargamos para que cualquier estado dependiente de sesión
    // (futuras vistas protegidas, saludos, etc.) se reinicie.
    window.location.reload();
  });

  pintarEstadoSesion();
});
</file>

<file path="CSS/login.css">
/* Login */
.login-main {
  padding: 70px 0;
  min-height: 70vh;
}

.login-card {
  background: #FFFFFF;
  border: 1px solid var(--bordercolor);
  border-radius: 24px;
  padding: 32px;
  box-shadow: var(--shadowsoft);
}

.login-title {
  background: var(--gradientdark);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-size: 2.4rem;
  font-weight: 800;
  text-align: center;
  margin-bottom: 10px;
}

.login-text {
  text-align: center;
  color: var(--colortextos);
  margin-bottom: 26px;
}

.login-card .form-label {
  font-weight: 600;
  color: var(--colortextos);
}

.login-card .form-control {
  border: 1px solid #D9D2C7;
  border-radius: 14px;
  min-height: 52px;
  padding: 12px 14px;
  box-shadow: none;
}

.login-card .form-control:focus {
  border-color: #6B5B4D;
  box-shadow: 0 0 0 0.16rem rgba(107, 91, 77, 0.18);
}

.login-btn {
  background-color: #FFFFFF;
  color: var(--navbackground);
  border: none;
  border-radius: 999px;
  padding: 14px 32px;
  font-weight: 800;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.10);
  transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}

.login-btn:hover {
  background-color: var(--navbackground);
  color: #FFFFFF;
  transform: translateY(-2px);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.16);
}

.login-message {
  text-align: center;
  margin-top: 16px;
  font-weight: 600;
  min-height: 1.2em;
}

.login-message.is-error {
  color: var(--dangercolor);
}

.login-message.is-success {
  color: var(--navbackground);
}

.login-footer-link {
  display: block;
  text-align: center;
  margin-top: 18px;
  color: var(--colortextos);
  font-size: 0.95rem;
}

.login-footer-link a {
  color: var(--colorhover);
  font-weight: 700;
}

.login-footer-link a:hover {
  text-decoration: underline;
}

.login-field-error {
  display: block;
  margin-top: 6px;
  min-height: 1.1em;
  font-size: 0.84rem;
  font-weight: 600;
  color: var(--dangercolor);
}
</file>

