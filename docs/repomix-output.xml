  justify-content: center;
  margin-top: 6px;
}

.admin-actions-gap {
  gap: 12px;
  flex-wrap: wrap;
}

.btn-admin {
  background-color: #ffffff;
  color: var(--navbackground);
  border: none;
  border-radius: 999px;
  padding: 14px 32px;
  min-width: 220px;
  font-weight: 800;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.10);
  transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}

.btn-admin:hover {
  background-color: var(--navbackground);
  color: #ffffff;
  transform: translateY(-2px);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.16);
}

.btn-admin-outline {
  background-color: transparent;
  color: var(--navbackground);
  border: 1px solid var(--navbackground);
  border-radius: 999px;
  padding: 14px 32px;
  min-width: 220px;
  font-weight: 800;
  transition: all 0.3s ease;
}

.btn-admin-outline:hover {
  background-color: rgba(110, 155, 119, 0.08);
}

/* =========================
   PRODUCTOS ADMIN
   ========================= */

#productList {
  align-items: stretch;
}

#productList > div {
  display: flex;
  width: 50%;
  max-width: 50%;
  flex: 0 0 50%;
}

#productList .product-card {
  width: 100%;
}

.product-card {
  background: #ffffff;
  border: 1px solid var(--bordercolor);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: var(--shadowsoft);
  transition: transform 0.3s ease, box-shadow 0.3s ease;

  width: 100%;
  height: 100%;
  min-height: 610px;

  display: flex;
  flex-direction: column;
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 14px 24px rgba(0, 0, 0, 0.12);
}

.product-image {
  width: 100%;
  height: 260px;
  object-fit: cover;
  object-position: center;
  flex-shrink: 0;
}

.product-card .card-body {
  padding: 22px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.badge-category {
  display: inline-block;
  width: fit-content;
  margin-bottom: 14px;
  padding: 7px 14px;
  border-radius: 999px;
  background: linear-gradient(135deg, #2C2A28 0%, #4B4138 45%, #6B5B4D 100%);
  color: #ffffff;
  font-size: 0.78rem;
  font-weight: 800;
  white-space: nowrap;
}

.product-card .card-title {
  font-size: 1.12rem;
  font-weight: 800;
  color: #202020;
  line-height: 1.3;
  min-height: 58px;
  margin-bottom: 10px;
  overflow: visible;
}

.product-card .card-text {
  font-size: 0.94rem;
  line-height: 1.5;
  color: #666666;
  min-height: 82px;
  margin-bottom: 14px;
  overflow: visible;
}

.price-text {
  color: #000000;
  font-size: 1.2rem;
  line-height: 1.3;
  font-weight: 800;
  margin-bottom: 10px;
  overflow: visible;
  white-space: normal;
}

.stock-text {
  font-size: 0.95rem;
  line-height: 1.3;
  font-weight: 700;
  color: #000000;
  margin-bottom: 16px;
  overflow: visible;
  white-space: normal;
}

.product-actions-inline {
  display: flex;
  flex-direction: row;
  gap: 8px;
  margin-top: auto;
  align-items: center;
  justify-content: center;
  flex-wrap: nowrap;
  width: 100%;
}

.btn-card-edit,
.btn-card-delete {
  border: none;
  border-radius: 999px;
  padding: 9px 14px;
  font-size: 0.82rem;
  line-height: 1.2;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.3s ease;
  min-width: 78px;
  text-align: center;
  white-space: nowrap;
}

.btn-card-edit {
  background: rgba(110, 155, 119, 0.12);
  color: #000000;
}

.btn-card-edit:hover {
  background: rgba(110, 155, 119, 0.22);
}

.btn-card-delete {
  background: rgba(176, 58, 46, 0.12);
  color: #000000;
}

.btn-card-delete:hover {
  background: rgba(176, 58, 46, 0.22);
}

.empty-state {
  background: rgba(110, 155, 119, 0.08);
  border: 1px dashed rgba(110, 155, 119, 0.28);
  border-radius: 18px;
  color: var(--colortextos);
  font-weight: 500;
  padding: 24px;
  text-align: center;
}

/* =========================
   RESPONSIVE
   ========================= */

@media (max-width: 1399px) {
  .product-card {
    min-height: 590px;
  }

  .product-image {
    height: 245px;
  }
}

@media (max-width: 1199px) {
  .admin-layout {
    grid-template-columns: 1fr;
  }

  #productList > div {
    width: 50%;
    max-width: 50%;
    flex: 0 0 50%;
  }

  .product-card {
    min-height: 570px;
  }
}

@media (max-width: 991px) {
  .admin-hero {
    height: 300px;
    min-height: 300px;
  }

  .btn-admin,
  .btn-admin-outline {
    width: 100%;
    min-width: unset;
  }

  #productList > div {
    width: 50%;
    max-width: 50%;
    flex: 0 0 50%;
  }

  .product-card {
    min-height: 560px;
  }

  .product-image {
    height: 240px;
  }
}

@media (max-width: 767px) {
  .admin-hero {
    height: 250px;
    min-height: 250px;
  }

  .admin-hero-title {
    font-size: 2.4rem;
  }

  .admin-hero-text {
    font-size: 1rem;
    padding: 0 10px;
  }

  .admin-card-header,
  .admin-form-body,
  .admin-products-body {
    padding-left: 18px;
    padding-right: 18px;
  }

  #productList > div {
    width: 100%;
    max-width: 100%;
    flex: 0 0 100%;
  }

  .product-card {
    min-height: auto;
  }

  .product-image {
    height: 240px;
  }

  .product-card .card-title,
  .product-card .card-text {
    min-height: unset;
  }

  .product-actions-inline {
    flex-wrap: nowrap;
  }
}
</file>

<file path="CSS/index.css">
/* =========================
   INDEX / HOME
   ========================= */

.carousel-item {
  position: relative;
  overflow: hidden;
}

.banner-img {
  display: block;
  width: 100%;
  height: 640px;
  object-fit: cover;
  object-position: center;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    rgba(0, 0, 0, 0.44),
    rgba(0, 0, 0, 0.30)
  );
  z-index: 1;
}

.carousel-caption.hero-content {
  z-index: 2;
  bottom: 24%;
}

.hero-content h1 {
  color: #ffffff;
  font-size: clamp(2.7rem, 6vw, 5rem);
  font-weight: 800;
  margin-bottom: 14px;
}

.hero-content p {
  color: #ffffff;
  font-size: 1.15rem;
  max-width: 760px;
  margin: 0 auto 22px;
}

/* =========================
   BOTONES HERO
   ========================= */

.hero-actions {
  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
}

.hero-btn-primary {
  background-color: #ffffff;
  color: #6E9B77 !important;
  border: none;
  border-radius: 999px;
  padding: 14px 32px;
  min-width: 210px;
  font-weight: 800;
  font-size: 1rem;
  text-align: center;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.16);
  transition:
    background-color 0.3s ease,
    color 0.3s ease,
    transform 0.3s ease,
    box-shadow 0.3s ease;
}

.hero-btn-primary:hover {
  background-color: #6E9B77;
  color: #ffffff !important;
  transform: translateY(-2px);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.22);
}

.hero-btn-secondary {
  background-color: rgba(255, 255, 255, 0.14);
  color: #ffffff !important;
  border: 1px solid rgba(255, 255, 255, 0.45);
  border-radius: 999px;
  padding: 14px 32px;
  min-width: 170px;
  font-weight: 800;
  font-size: 1rem;
  text-align: center;
  backdrop-filter: blur(4px);
  transition:
    background-color 0.3s ease,
    color 0.3s ease,
    transform 0.3s ease,
    border-color 0.3s ease;
}

.hero-btn-secondary:hover {
  background-color: rgba(255, 255, 255, 0.24);
  color: #ffffff !important;
  border-color: rgba(255, 255, 255, 0.75);
  transform: translateY(-2px);
}

/* =========================
   CARRUSEL
   ========================= */

.carousel,
.carousel-inner,
.carousel-item {
  margin-bottom: 0 !important;
  padding-bottom: 0 !important;
}

.carousel-control-prev,
.carousel-control-next {
  z-index: 3;
}

.carousel-indicators {
  z-index: 3;
}

.carousel-indicators [data-bs-target] {
  width: 34px;
  height: 3px;
  border-radius: 999px;
}

/* =========================
   CATEGORÍAS
   ========================= */

.categories-section {
  padding: 44px 0 60px;
  background-color: var(--backgroundcolor);
}

.section-heading {
  margin-bottom: 26px;
}

.section-title {
  background: linear-gradient(
    135deg,
    #2C2A28 0%,
    #5A4C42 45%,
    #8A735F 100%
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;

  font-size: clamp(2.2rem, 3vw, 3rem);
  font-weight: 800;
  margin-bottom: 10px;
}

.section-subtitle {
  max-width: 820px;
  margin: 0 auto;
  font-size: 1rem;
  line-height: 1.65;
  color: var(--colortextos);
}

.categories-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 22px;
}

.category-card {
  background: var(--cardbg);
  border: 1px solid var(--bordercolor);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: var(--shadowsoft);
  transition:
    transform 0.3s ease,
    box-shadow 0.3s ease;
}

.category-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 14px 24px rgba(0, 0, 0, 0.12);
}

.category-image-wrapper {
  height: 220px;
  overflow: hidden;
}

.category-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.category-content {
  padding: 18px 18px 20px;
  text-align: center;
}

.category-content h3 {
  color: var(--navbackground);
  font-size: 1.3rem;
  font-weight: 800;
  margin-bottom: 8px;
}

.category-content p {
  font-size: 0.95rem;
  line-height: 1.55;
  margin-bottom: 0;
  color: var(--colortextos);
}

/* =========================
   CTA
   ========================= */

.cta-section {
  padding: 0 0 60px;
  background-color: var(--backgroundcolor);
}

.cta-box {
  background:
    linear-gradient(
      rgba(0, 0, 0, 0.32),
      rgba(0, 0, 0, 0.32)
    ),
    url("../IMG/hero-artesanal-colombia.jpg");

  background-position: center center;
  background-size: cover;
  background-repeat: no-repeat;

  border: 1px solid var(--bordercolor);
  border-radius: 28px;
  padding: 44px 36px;
  box-shadow: var(--shadowsoft);

  min-height: 310px;

  display: flex;
  align-items: center;
}

.cta-text-overlay {
  max-width: 760px;
}

.cta-label {
  display: inline-block;
  margin-bottom: 12px;
  padding: 7px 14px;
  border-radius: 999px;

  background: linear-gradient(
    135deg,
    #2C2A28 0%,
    #4B4138 45%,
    #6B5B4D 100%
  );

  color: #ffffff;
  font-size: 0.85rem;
  font-weight: 800;
  letter-spacing: 0.3px;
}

.cta-text-overlay h2,
.cta-text h2 {
  color: #ffffff;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 800;
  margin-bottom: 12px;
}

.cta-text-overlay p,
.cta-text p {
  color: #ffffff;
  margin: 0;
  line-height: 1.65;
  max-width: 720px;
}

.cta-action {
  margin-top: 24px;
}

.cta-btn {
  background-color: #ffffff;
  color: #6E9B77 !important;
  border: none;
  border-radius: 999px;
  padding: 14px 32px;
  min-width: 180px;
  font-weight: 800;
  font-size: 1rem;
  text-align: center;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.16);
  transition:
    background-color 0.3s ease,
    color 0.3s ease,
    transform 0.3s ease,
    box-shadow 0.3s ease;
}

.cta-btn:hover {
  background-color: #6E9B77;
  color: #ffffff !important;
  transform: translateY(-2px);
  box-shadow: 0 12px 26px rgba(0, 0, 0, 0.22);
}

/* =========================
   RESPONSIVE
   ========================= */

@media (max-width: 991px) {
  .banner-img {
    height: 540px;
  }

  .carousel-caption.hero-content {
    bottom: 18%;
  }

  .categories-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .cta-box {
    min-height: 280px;
    padding: 36px 28px;
  }
}

@media (max-width: 767px) {
  .banner-img {
    height: 430px;
  }

  .carousel-caption.hero-content {
    bottom: 12%;
  }

  .hero-content h1 {
    font-size: 2.4rem;
  }

  .hero-content p {
    font-size: 1rem;
    padding: 0 10px;
  }

  .hero-actions {
    gap: 10px;
  }

  .hero-btn-primary,
  .hero-btn-secondary,
  .cta-btn {
    width: 100%;
    min-width: unset;
  }

  .section-title {
    font-size: 2rem;
  }

  .categories-grid {
    grid-template-columns: 1fr;
  }

  .cta-box {
    min-height: 260px;
    padding: 28px 20px;
    text-align: center;
  }

  .cta-text-overlay {
    margin: 0 auto;
  }
}
</file>

